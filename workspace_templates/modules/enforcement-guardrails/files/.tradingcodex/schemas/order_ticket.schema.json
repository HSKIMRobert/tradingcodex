{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TradingCodex Order Ticket",
  "type": "object",
  "required": [
    "ticket_id",
    "symbol",
    "side",
    "quantity",
    "limit_price",
    "currency",
    "broker_id",
    "broker_account_id",
    "estimated_notional",
    "native_notional",
    "base_currency",
    "fx_rate",
    "fx_source_snapshot_id",
    "fx_as_of",
    "portfolio_id",
    "account_id",
    "strategy_id",
    "order_type",
    "time_in_force",
    "created_by",
    "created_at",
    "canonical_order",
    "money"
  ],
  "properties": {
    "ticket_id": { "type": "string", "minLength": 1 },
    "symbol": { "type": "string" },
    "side": { "enum": ["buy", "sell"] },
    "quantity": { "type": ["number", "string"] },
    "limit_price": { "type": ["number", "string"] },
    "currency": { "type": "string" },
    "broker_id": { "type": "string", "minLength": 1 },
    "broker_account_id": { "type": "string", "minLength": 1 },
    "estimated_notional": { "type": ["number", "string"] },
    "native_notional": { "type": ["number", "string"] },
    "base_currency": { "type": "string" },
    "fx_rate": { "type": ["number", "string"] },
    "fx_source_snapshot_id": { "type": "string" },
    "fx_as_of": { "type": "string" },
    "created_by": { "type": "string" },
    "created_at": { "type": "string" },
    "portfolio_id": { "type": "string" },
    "account_id": { "type": "string" },
    "strategy_id": { "type": "string" },
    "order_type": { "type": "string" },
    "time_in_force": { "type": "string" },
    "canonical_order": { "type": "object" },
    "money": { "type": "object" }
  },
  "additionalProperties": false
}
