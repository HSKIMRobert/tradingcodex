{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TradingCodex Approval Receipt",
  "type": "object",
  "required": [
    "approval_receipt_id",
    "ticket_id",
    "broker_id",
    "broker_account_id",
    "approved_by",
    "valid",
    "created_at",
    "expires_at",
    "exact_order_hash",
    "max_notional",
    "max_price",
    "approved_order_type",
    "approved_time_in_force",
    "valid_until",
    "quote_as_of_requirement",
    "policy_decision"
  ],
  "properties": {
    "approval_receipt_id": { "type": "string" },
    "ticket_id": { "type": "string" },
    "broker_id": { "type": "string" },
    "broker_account_id": { "type": "string" },
    "approved_by": { "type": "string" },
    "valid": { "type": "boolean" },
    "created_at": { "type": "string" },
    "expires_at": { "type": "string" },
    "exact_order_hash": { "type": "string" },
    "max_notional": { "type": ["number", "string"] },
    "max_price": { "type": ["number", "string"] },
    "max_slippage_bps": { "type": ["integer", "null"] },
    "approved_order_type": { "type": "string" },
    "approved_time_in_force": { "type": "string" },
    "valid_until": { "type": "string" },
    "quote_as_of_requirement": { "type": "string" },
    "consumed_at": { "type": ["string", "null"] },
    "superseded_at": { "type": ["string", "null"] },
    "policy_decision": { "type": "object" }
  },
  "additionalProperties": false
}
