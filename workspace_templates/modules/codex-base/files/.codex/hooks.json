{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} session-start",
            "timeout": 10,
            "statusMessage": "Preparing TradingCodex subagent roster"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} pre-tool-use",
            "timeout": 10,
            "statusMessage": "Checking TradingCodex tool policy"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash|bash|shell|.*exec_command|.*write_stdin|unified_exec|mcp__.*|apply_patch|Edit|Write|spawn_agent",
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} permission-request",
            "timeout": 10,
            "statusMessage": "Reviewing TradingCodex permission request"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|bash|shell|.*exec_command|.*write_stdin|unified_exec|mcp__.*|apply_patch|Edit|Write|spawn_agent",
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} post-tool-use",
            "timeout": 10,
            "statusMessage": "Recording TradingCodex audit event"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} user-prompt-submit",
            "timeout": 600,
            "statusMessage": "Checking TradingCodex native action and analysis context"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "fundamental-analyst|technical-analyst|news-analyst|macro-analyst|instrument-analyst|valuation-analyst|portfolio-manager|risk-manager|judgment-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} subagent-start",
            "timeout": 10,
            "statusMessage": "Recording TradingCodex subagent start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "fundamental-analyst|technical-analyst|news-analyst|macro-analyst|instrument-analyst|valuation-analyst|portfolio-manager|risk-manager|judgment-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} subagent-stop",
            "timeout": 10,
            "statusMessage": "Recording TradingCodex subagent stop"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} stop",
            "timeout": 30,
            "statusMessage": "Validating TradingCodex artifacts"
          }
        ]
      }
    ]
  }
}
