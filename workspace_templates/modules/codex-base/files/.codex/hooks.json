{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} session-start",
            "timeout": 10,
            "statusMessage": "Preparing TradingCodex subagent roster"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} pre-tool-use",
            "timeout": 10,
            "statusMessage": "Checking TradingCodex tool policy"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*exec_command|.*write_stdin|mcp__tradingcodex__use_order_turn_grant",
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} permission-request",
            "timeout": 10,
            "statusMessage": "Checking TradingCodex order effect"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} user-prompt-submit",
            "timeout": 600,
            "statusMessage": "Checking TradingCodex native action and analysis context"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} subagent-start",
            "timeout": 10,
            "statusMessage": "Recording TradingCodex subagent start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} subagent-stop",
            "timeout": 10,
            "statusMessage": "Recording TradingCodex subagent stop"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{TRADINGCODEX_HOOK_COMMAND_JSON_INNER}} stop",
            "timeout": 30,
            "statusMessage": "Validating TradingCodex artifacts"
          }
        ]
      }
    ]
  }
}
