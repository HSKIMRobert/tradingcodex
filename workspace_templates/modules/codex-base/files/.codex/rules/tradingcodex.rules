# TradingCodex agent-shell command policy. Human/operator CLI use is unchanged.

prefix_rule(
    pattern = ["./tcx", "mcp", "call"],
    decision = "forbidden",
    justification = "Agent role identity comes from the project MCP transport, not a caller-selected CLI principal.",
    match = ["./tcx mcp call create_research_artifact --principal fundamental-analyst"],
)

prefix_rule(
    pattern = ["./tcx", "research", "create"],
    decision = "forbidden",
    justification = "Agents store final research through their authenticated TradingCodex MCP writer.",
    match = ["./tcx research create --markdown-file trading/research/.drafts/note.md --universe public_equity"],
)

prefix_rule(
    pattern = ["./tcx", "research", "append"],
    decision = "forbidden",
    justification = "Agents revise research through their authenticated TradingCodex MCP writer.",
    match = ["./tcx research append note-1 --markdown-file trading/research/.drafts/note.md"],
)

prefix_rule(
    pattern = ["./tcx", "research", "export"],
    decision = "forbidden",
    justification = "Agent artifact writes use authenticated TradingCodex MCP tools.",
    match = ["./tcx research export note-1"],
)

prefix_rule(
    pattern = ["./tcx", "research", "run-card"],
    decision = "forbidden",
    justification = "Agent evidence-card writes use authenticated TradingCodex MCP tools.",
    match = ["./tcx research run-card trading/research/note.md"],
)

prefix_rule(
    pattern = ["./tcx", "research", "validation-card"],
    decision = "forbidden",
    justification = "Agent validation-card writes use authenticated TradingCodex MCP tools.",
    match = ["./tcx research validation-card trading/research/note.md"],
)

prefix_rule(
    pattern = ["./tcx", "research", "spec", "create"],
    decision = "forbidden",
    justification = "Agent ResearchSpec writes use authenticated TradingCodex MCP tools.",
    match = ["./tcx research spec create spec.json --principal fundamental-analyst"],
)

prefix_rule(
    pattern = ["./tcx", "research", "replay", "create"],
    decision = "forbidden",
    justification = "Agent replay writes use authenticated TradingCodex MCP tools.",
    match = ["./tcx research replay create replay.json --principal fundamental-analyst"],
)

prefix_rule(
    pattern = ["./tcx", "research", "experiment", "record"],
    decision = "forbidden",
    justification = "Agent experiment writes use authenticated TradingCodex MCP tools.",
    match = ["./tcx research experiment record run.json --principal technical-analyst"],
)

prefix_rule(
    pattern = ["./tcx", "research", "index", "rebuild"],
    decision = "forbidden",
    justification = "Agents do not mutate the research index from shell.",
    match = ["./tcx research index rebuild"],
)

prefix_rule(
    pattern = ["./tcx", "research", "causal-analysis"],
    decision = "forbidden",
    justification = "Agent analysis writes use authenticated TradingCodex MCP tools.",
    match = ["./tcx research causal-analysis analysis.json --principal valuation-analyst"],
)

prefix_rule(
    pattern = ["./tcx", "research", "judgment-prior"],
    decision = "forbidden",
    justification = "Agent judgment writes use authenticated TradingCodex MCP tools.",
    match = ["./tcx research judgment-prior prior.json --principal judgment-reviewer"],
)

prefix_rule(
    pattern = ["./tcx", "research", "judgment-review"],
    decision = "forbidden",
    justification = "Agent judgment writes use authenticated TradingCodex MCP tools.",
    match = ["./tcx research judgment-review review.json --principal judgment-reviewer"],
)

prefix_rule(
    pattern = ["./tcx", "forecast", "issue"],
    decision = "forbidden",
    justification = "Agent forecast writes use authenticated TradingCodex MCP tools.",
    match = ["./tcx forecast issue forecast.json --principal fundamental-analyst"],
)

prefix_rule(
    pattern = ["./tcx", "forecast", "revise"],
    decision = "forbidden",
    justification = "Agent forecast writes use authenticated TradingCodex MCP tools.",
    match = ["./tcx forecast revise forecast.json --principal fundamental-analyst"],
)

prefix_rule(
    pattern = ["./tcx", "forecast", "resolve"],
    decision = "forbidden",
    justification = "Agent forecast resolution uses authenticated TradingCodex MCP tools.",
    match = ["./tcx forecast resolve forecast.json --principal judgment-reviewer"],
)

prefix_rule(
    pattern = ["./tcx", "forecast", "score"],
    decision = "forbidden",
    justification = "Agent forecast scoring uses authenticated TradingCodex MCP tools.",
    match = ["./tcx forecast score forecast-1 --principal judgment-reviewer"],
)

prefix_rule(
    pattern = ["./tcx", "evaluation"],
    decision = "forbidden",
    justification = "Agent evaluation identity comes from authenticated TradingCodex MCP, not --principal.",
    match = ["./tcx evaluation run evaluation.json --principal head-manager"],
)

prefix_rule(
    pattern = ["./tcx", "validate", "order"],
    decision = "forbidden",
    justification = "Agent order checks use the role-authenticated TradingCodex service boundary.",
    match = ["./tcx validate order ticket-1"],
)

prefix_rule(
    pattern = ["./tcx", "risk-check"],
    decision = "forbidden",
    justification = "Agent risk checks use the risk-manager authenticated TradingCodex service boundary.",
    match = ["./tcx risk-check ticket-1"],
)

prefix_rule(
    pattern = ["./tcx", "approve"],
    decision = "forbidden",
    justification = "Agent approval identity comes from authenticated TradingCodex MCP, not --approved-by.",
    match = ["./tcx approve ticket-1 --approved-by risk-manager"],
)
